{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Subsystem Emergence Ledger Record",
  "type": "object",
  "required": [
    "benchmark_id",
    "branch",
    "theorem_tier",
    "parameter_id",
    "seed",
    "parameters",
    "metadata",
    "observables"
  ],
  "properties": {
    "benchmark_id": { "type": "string" },
    "branch": { "type": "string" },
    "theorem_tier": { "type": "string" },
    "parameter_id": { "type": "string" },
    "seed": { "type": "integer" },
    "parameters": { "type": "object" },
    "metadata": {
      "type": "object",
      "properties": {
        "code_hash": { "type": ["string", "null"] },
        "solver": { "type": "string" },
        "runtime_seconds": { "type": "number" },
        "source_of_truth": { "type": "object" }
      },
      "required": ["solver", "runtime_seconds"]
    },
    "observables": {
      "type": "object",
      "required": [
        "spectral_gap",
        "singular_gap",
        "projector_deformation",
        "coherent_projector_deformation",
        "block_residual_norm",
        "leakage_trajectory",
        "autonomy_horizon",
        "cross_subsystem_transfer_rate",
        "reduced_model_forecast_error",
        "transient_amplification_score",
        "ensemble_averaged_leakage",
        "leakage_variance",
        "affine_law_regression_coefficients",
        "transportability_metrics",
        "coordinate_sensitivity_metrics",
        "numerical_refinement_metrics"
      ],
      "properties": {
        "spectral_gap": { "type": ["number", "null"] },
        "singular_gap": { "type": ["number", "null"] },
        "projector_deformation": { "type": ["number", "null"] },
        "coherent_projector_deformation": { "type": ["number", "null"] },
        "block_residual_norm": { "type": ["number", "null"] },
        "leakage_trajectory": { "type": ["array", "null"], "items": { "type": "number" } },
        "autonomy_horizon": { "type": ["number", "integer", "null"] },
        "cross_subsystem_transfer_rate": { "type": ["number", "null"] },
        "reduced_model_forecast_error": { "type": ["number", "null"] },
        "transient_amplification_score": { "type": ["number", "null"] },
        "ensemble_averaged_leakage": { "type": ["number", "null"] },
        "leakage_variance": { "type": ["number", "null"] },
        "affine_law_regression_coefficients": { "type": ["object", "null"] },
        "transportability_metrics": { "type": ["object", "null"] },
        "coordinate_sensitivity_metrics": { "type": ["object", "null"] },
        "numerical_refinement_metrics": { "type": ["object", "null"] }
      },
      "additionalProperties": true
    },
    "law_fits": { "type": "object" },
    "law_selection_summary": { "type": "object" },
    "gate_outcomes": { "type": "object" },
    "failure_labels": { "type": "array", "items": { "type": "string" } },
    "figure_references": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  }
}
